  {
    "id": "cal_free_busy_009",
    "layer": 2,
    "tool": "shell",
    "mode": "script",
    "task": "Given an ICS file with 3 events throughout the day, calculate the free time slots between 09:00 and 18:00. Write the free slots (start-end format) to /tmp/clive/result.txt, one per line.",
    "initial_state": {
      "setup": "printf 'BEGIN:VCALENDAR\\nBEGIN:VEVENT\\nSUMMARY:Meeting 1\\nDTSTART:20260415T100000\\nDTEND:20260415T110000\\nEND:VEVENT\\nBEGIN:VEVENT\\nSUMMARY:Meeting 2\\nDTSTART:20260415T130000\\nDTEND:20260415T140000\\nEND:VEVENT\\nBEGIN:VEVENT\\nSUMMARY:Meeting 3\\nDTSTART:20260415T160000\\nDTEND:20260415T170000\\nEND:VEVENT\\nEND:VCALENDAR' > /tmp/clive/day.ics"
    },
    "success_criteria": {
      "type": "deterministic",
      "check": "test -f /tmp/clive/result.txt && grep -qE '[0-9]{2}:[0-9]{2}' /tmp/clive/result.txt && test $(wc -l < /tmp/clive/result.txt | tr -d ' ') -ge 3"
    },
    "min_turns": 1,
    "max_turns": 8,
    "timeout_seconds": 45
  },
