[
  {
    "id": "cal_create_event_001",
    "layer": 2,
    "tool": "shell",
    "mode": "script",
    "task": "Create an ICS calendar event file at /tmp/clive/meeting.ics for a meeting titled 'Q2 Planning' on 2026-04-15 from 14:00 to 15:30 CET with attendee kiu@ikangai.com. Write the full path to /tmp/clive/result.txt.",
    "initial_state": {},
    "success_criteria": {
      "type": "deterministic",
      "check": "test -f /tmp/clive/meeting.ics && grep -q 'Q2 Planning' /tmp/clive/meeting.ics && grep -q 'VEVENT' /tmp/clive/meeting.ics"
    },
    "min_turns": 1,
    "max_turns": 5,
    "timeout_seconds": 30
  },
  {
    "id": "cal_parse_ics_002",
    "layer": 2,
    "tool": "shell",
    "mode": "script",
    "task": "Parse the ICS file at /tmp/clive/meeting.ics and extract the event summary (SUMMARY field). Write just the summary text to /tmp/clive/result.txt.",
    "initial_state": {
      "setup": "printf 'BEGIN:VCALENDAR\\nBEGIN:VEVENT\\nSUMMARY:Q2 Planning\\nDTSTART:20260415T140000\\nDTEND:20260415T153000\\nATTENDEE:mailto:kiu@ikangai.com\\nEND:VEVENT\\nEND:VCALENDAR' > /tmp/clive/meeting.ics"
    },
    "success_criteria": {
      "type": "deterministic",
      "check": "grep -q 'Q2 Planning' /tmp/clive/result.txt"
    },
    "min_turns": 1,
    "max_turns": 5,
    "timeout_seconds": 30
  },
  {
